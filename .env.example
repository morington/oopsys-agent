DEV=false

APPLICATION__HOST=0.0.0.0
APPLICATION__PORT=8080

SQLITE__PATH=data/oopsys-agent.db

NATS__ENABLED=true
NATS__SERVERS=["nats://nats:4222"]
NATS__STREAM=OOPSYS
NATS__SUBJECT_PREFIX=oopsys

INTERVALS__METRICS_SECONDS=30
INTERVALS__PUBLISH_SECONDS=5
INTERVALS__RETRY_BASE_SECONDS=5
INTERVALS__RETRY_MAX_SECONDS=300

AGENT__NAME=oopsys-agent
