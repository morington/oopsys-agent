DEV=false

APPLICATION__HOST=0.0.0.0
APPLICATION__PORT=8080

SQLITE__PATH=data/oopsys-agent.db

NATS__SERVERS=["nats://oopsys-nats:4222"]
NATS__STREAM=OOPSYS
NATS__SUBJECT_PREFIX=oopsys
NATS__DURABLE=oopsys-forwarder
NATS__ACK_WAIT=60

SERVER__URL=http://oopsys-server:8000
SERVER__INGEST_PATH=/agents/ingest
SERVER__TIMEOUT=10

INTERVALS__METRICS_SECONDS=30
INTERVALS__RETRY_BASE_SECONDS=5

AGENT__NAME=oopsys-agent
# AGENT__TOKEN=
